# Required: GitHub personal access token
# Fine-grained scopes needed: Pull Requests (read/write), Contents (read), Metadata (read)
PAT_TOKEN=

# Optional: GitHub MCP server endpoint (for MCP-based connection, alternative to direct Octokit)
# Smithery hosted: https://server.smithery.ai/@modelcontextprotocol/server-github/mcp
GITHUB_MCP_URL=

# Optional: OpenCode API key (only needed if using an OpenCode MCP proxy)
OPENCODE_API_KEY=

# Optional: Slack incoming webhook URL for critical-issue alerts
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
